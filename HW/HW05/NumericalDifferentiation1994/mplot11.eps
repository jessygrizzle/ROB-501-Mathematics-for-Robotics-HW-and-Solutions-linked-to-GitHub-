%=======================  USER CONFIGURABLE PARAMETERS  ========================
% Orientation:  0=portrait,   1=landscape
% Color         0=Black&White 1=Color
% X Y scaling:  1=largest size, .5=half size, etc
% X justify:    1=left,  2=center,3=right, >3=offset(units .01 in) from left
% Y justify:    1=bottom,2=center,3=top    >3=offset(units .01 in) from bottom
% Encapsulated PostScript: 0=no, 1=yes.  %%BoundingBox xy scaling is 1 1
%                          if xy scaling is changed manually, %%BoundingBox
%                          above must be recalculated using  0 0 boxw boxh
%                          (see PostScript calculations for boxw,boxh below)
/PSland     1 def      /PScolor    0 def
/PSxscale   1 def      /PSyscale   1 def
/PSxjust    1 def      /PSyjust    1 def
/PSeps      1 def       
%===============================================================================
PSland 1 eq {/grafw 696 def /grafh 540 def}
            {/grafw 540 def /grafh 696 def} ifelse
PSeps  1 ne {initgraphics  PSland 1 eq {90 rotate 48 -576 translate}
                                       {36 48 translate } ifelse } if
/xmax 1 def  /ymax 0.69481 def
/boxw grafw PSxscale mul def  /boxh grafw PSyscale mul ymax xmax div mul def
boxh grafh gt {/boxw grafh boxh div boxw mul def  /boxh grafh def} if 
%
/np /newpath load def   /cp /closepath load def
/rm /rmoveto load def   /rl /rlineto load def
/mt /moveto  load def   /lt /lineto  load def
/st /stroke  load def   /sw /setlinewidth load def
/pt {moveto closepath stroke} def  /pp {2 copy pt neg pt} def
/P2 {moveto rlineto stroke} def    /P3 {moveto rlineto rlineto stroke} def
/dl {/ll exch def /ls exch def} def
/vl {ls moveto 0 ll rlineto stroke} def
/hl {ls exch moveto ll 0 rlineto stroke} def
/mvl {/n exch def dl /ml exch def /ms exch def
       n {ms vl /ms ms ml add def} repeat} def
/mhl {/n exch def dl /ml exch def /ms exch def
       n {ms hl /ms ms ml add def} repeat} def
/trsw  {tr3wid mul setlinewidth} def
/RECT  {/h exch def /w exch def np mt 0 h rl  w 0 rl  0 h neg rl  cp} def
/TEXT  {0 fh -.72 mul rmoveto show} def
/TEXTC {dup stringwidth pop -.5 mul fh -.35 mul rmoveto show} def
/TEXTJ {/xyj exch def dup stringwidth pop -.5 mul 
         xyj 10 idiv 1 sub mul -.72 -.35 .23 xyj 10 mod 1 sub
         index 4 1 roll pop pop pop fh mul rmoveto show} def
/BAR   {-48 div 1 add setgray RECT fill 0 setgray} def
/MARK  {mt dup stringwidth pop -.525 mul fh -.35 mul rmoveto show} def
/STAR  {mt (X) stringwidth pop -.525 mul fh -1.1 mul rmoveto 2 2 scale
        currentlinewidth (*) false charpath 1 trsw stroke .5 .5 scale sw} def
/TSIZE {/fh exch def .75 div /fw exch def /Helvetica-Bold
         findfont [fw 0 0 fh 0 0] makefont setfont} def
/TRANS {/TY exch def /TX exch def /SY exch def /SX exch def grestore gsave
         SX SY scale TX TY translate  /tr3mat matrix currentmatrix def
        /tr3wid vdwid SX div def  /cw 3 tr3wid mul def  3 trsw} def
%
0 0 0 setrgbcolor [] 0 setdash 2 setlinejoin 0 setlinecap
/dots boxw .24 div def  /vdwid xmax dots div def
%
PSxjust abs 3 gt {PSxjust .72 mul}
{grafw boxw sub 0 PSxjust 2 eq {pop .5} if PSxjust 3 eq {pop 1} if mul} ifelse
PSyjust abs 3 gt {PSyjust .72 mul}
{grafh boxh sub 0 PSyjust 2 eq {pop .5} if PSyjust 3 eq {pop 1} if mul} ifelse
translate
%
boxw xmax div boxh ymax div scale
/vdmat matrix currentmatrix def gsave
